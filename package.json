{
  "name": "claude-skills-hub",
  "version": "0.1.0",
  "private": true,
  "description": "Catalogue visuel des skills Claude (Code, Cowork, plugins) avec filtres par catégorie, recherche et actions rapides.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "scan": "tsx scripts/scan-skills.ts",
    "scan:default": "tsx scripts/scan-skills.ts --input ~/.claude/skills --input ~/.claude/plugins --input ./my-skills --output data/skills.json"
  },
  "dependencies": {
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.469.0",
    "next": "15.1.6",
    "next-themes": "^0.4.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^9.0.3",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.1.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
